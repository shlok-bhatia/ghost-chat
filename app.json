{
  "expo": {
    "name": "ghost-chat",
    "slug": "ghost-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ghostchat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.shlokbhatia.ghostchat"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "461bcba3-baf4-43d7-a886-55424d656ebf"
      }
    },
    "owner": "shlokbhatia"
  }
}
