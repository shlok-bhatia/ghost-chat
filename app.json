{
  "expo": {
    "name": "ghost-chat",
    "slug": "ghost-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ghostchat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

     "icon": "./assets/ghost-chat-icon.png",

     "splash": {
      "image": "./assets/splash-screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A0814"
    },

    "ios": {
      "supportsTablet": true,
       "icon": "./assets/ghost-chat-icon.png"
    },
    "android": {
      "package": "com.shlokbhatia.ghostchat",
       "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/adaptive-icon-background.png",
        "backgroundColor": "#0A0814"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/ghost-chat-icon.png"
    },
    "plugins": [
      "expo-router",
      
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "461bcba3-baf4-43d7-a886-55424d656ebf"
      }
    },
    "owner": "shlokbhatia"
  }
}
